# Copia este archivo a .env y rellena con valores reales.
# NUNCA commitees el archivo .env (ya está en .gitignore).

# --- Base de datos ---
DB_USER=opti_admin
# Usa una contraseña fuerte y única en producción.
DB_PASSWORD=CAMBIA_ESTA_CONTRASENA
# Puerto del HOST para acceder a la DB de Docker en local (psql/pgAdmin).
# Cámbialo si el 5433 está ocupado. La app no lo usa (va por la red de Docker).
DB_HOST_PORT=5433

# --- Seguridad ---
# Secreto de firma de los JWT (HS256). Genera uno nuevo y único por entorno:
#   openssl rand -base64 32
# El secreto anterior estuvo commiteado en el repo: NO lo reutilices.
JWT_SECRET=GENERA_UN_SECRETO_NUEVO_BASE64

# Cookies con flag Secure. true en producción (requiere HTTPS). false en local.
COOKIE_SECURE=false
# SameSite de cookies: Lax (mismo dominio) o None (dominios distintos; exige COOKIE_SECURE=true).
COOKIE_SAMESITE=Lax

# --- Esquema / datos ---
# Flyway gestiona el esquema; Hibernate solo valida. Usa 'validate' (o 'none').
DDL_AUTO=validate
# Carga de datos de ejemplo (DataSeeder). En producción: false.
SEED_ENABLED=true

# --- CORS ---
# Orígenes del frontend permitidos (coma-separado). En prod: tu dominio real.
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# URL pública del frontend, la que se usa para armar los enlaces de los correos
# (p. ej. el de recuperar contraseña). En producción: tu dominio real con https.
# Ojo: NO es lo mismo que APP_CORS_ALLOWED_ORIGINS, que es una lista de orígenes permitidos.
FRONTEND_PUBLIC_URL=http://localhost:3000

# --- Marca ---
# Nombre del producto tal como lo ve el cliente (asuntos y cuerpos de los correos).
BRAND_NAME=Fóvea
# Quien lo desarrolla; aparece solo en el pie de los correos ("hecho por VLK").
# Déjalo vacío si no quieres que se muestre.
BRAND_MAKER=VLK

# --- Correo ---
# 'log': no envía, escribe el correo (con el enlace de recuperación) en el log del servidor.
# Es el modo de desarrollo. 'smtp': envía de verdad.
# NO uses 'log' en producción: dejaría en los logs enlaces válidos para tomar una cuenta.
MAIL_PROVIDER=log
# Remitente. Debe ser una dirección de un dominio TUYO con SPF/DKIM configurados en el
# proveedor. No pongas aquí el correo de un cliente (su Gmail): los correos se irían a spam,
# porque nuestro servidor no está autorizado a enviar en nombre de gmail.com.
MAIL_FROM=no-reply@fovea.com.mx
# Si lo dejas vacío, se usa BRAND_NAME.
MAIL_FROM_NAME=

# Datos del proveedor SMTP (solo si MAIL_PROVIDER=smtp). Ejemplos de host:
#   Brevo: smtp-relay.brevo.com | Gmail: smtp.gmail.com | SES: email-smtp.<región>.amazonaws.com
MAIL_HOST=smtp.tuproveedor.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
