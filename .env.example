# Copia este archivo a .env y rellena con valores reales.
# NUNCA commitees el archivo .env (ya está en .gitignore).

# --- Base de datos ---
DB_USER=opti_admin
# Usa una contraseña fuerte y única en producción.
DB_PASSWORD=CAMBIA_ESTA_CONTRASENA
# Puerto del HOST para acceder a la DB de Docker en local (psql/pgAdmin).
# Cámbialo si el 5433 está ocupado. La app no lo usa (va por la red de Docker).
DB_HOST_PORT=5433

# --- Seguridad ---
# Secreto de firma de los JWT (HS256). Genera uno nuevo y único por entorno:
#   openssl rand -base64 32
# El secreto anterior estuvo commiteado en el repo: NO lo reutilices.
JWT_SECRET=GENERA_UN_SECRETO_NUEVO_BASE64

# Cookies con flag Secure. true en producción (requiere HTTPS). false en local.
COOKIE_SECURE=false
# SameSite de cookies: Lax (mismo dominio) o None (dominios distintos; exige COOKIE_SECURE=true).
COOKIE_SAMESITE=Lax

# --- Esquema / datos ---
# Flyway gestiona el esquema; Hibernate solo valida. Usa 'validate' (o 'none').
DDL_AUTO=validate
# Carga de datos de ejemplo (DataSeeder). En producción: false.
SEED_ENABLED=true

# --- CORS ---
# Orígenes del frontend permitidos (coma-separado). En prod: tu dominio real.
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
